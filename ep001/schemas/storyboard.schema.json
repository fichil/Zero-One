{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "集数",
    "标题",
    "平台",
    "画幅",
    "预计时长秒",
    "故事梗概",
    "分镜"
  ],
  "properties": {
    "集数": {
      "type": "string",
      "const": "EP001"
    },
    "标题": {
      "type": "string"
    },
    "平台": {
      "type": "string",
      "const": "抖音"
    },
    "画幅": {
      "type": "string",
      "const": "9:16"
    },
    "预计时长秒": {
      "type": "integer",
      "minimum": 45,
      "maximum": 90
    },
    "故事梗概": {
      "type": "string"
    },
    "分镜": {
      "type": "array",
      "minItems": 8,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "镜头编号",
          "时长秒",
          "角色动作",
          "表情",
          "台词",
          "特效或背景描述"
        ],
        "properties": {
          "镜头编号": {
            "type": "string",
            "pattern": "^S[0-9]{2}$"
          },
          "时长秒": {
            "type": "integer",
            "minimum": 3,
            "maximum": 10
          },
          "角色动作": {
            "type": "string"
          },
          "表情": {
            "type": "string"
          },
          "台词": {
            "type": "string"
          },
          "特效或背景描述": {
            "type": "string"
          }
        }
      }
    }
  }
}
